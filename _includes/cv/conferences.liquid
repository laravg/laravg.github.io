<ul class="card-text font-weight-light list-group list-group-flush">
  {% for entry in entries %}
    {% assign year = '' %}
    {% if entry.year %}
      {% assign year = entry.year %}
    {% elsif entry.date %}
      {% assign year = entry.date | slice: 0, 4 %}
    {% elsif entry.start_date %}
      {% assign year = entry.start_date | slice: 0, 4 %}
    {% endif %}

    <li class="list-group-item">
      <div class="row">
        {% if year != '' %}
          <div class="col-xs-2 col-sm-2 col-md-2 text-center">
            <table class="table-cv">
              <tbody>
                <tr>
                  <td>
                    <span class="badge font-weight-bold danger-color-dark text-uppercase align-middle" style="min-width: 75px">{{ year }}</span>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
          <div class="col-xs-10 col-sm-10 col-md-10 mt-2 mt-md-0">
            {% if entry.title %}
              {% if entry.url %}
                <h6 class="title font-weight-bold ml-1 ml-md-4">
                  <a href="{{ entry.url }}" target="_blank" rel="noopener noreferrer">{{ entry.title }}</a>
                </h6>
              {% else %}
                <h6 class="title font-weight-bold ml-1 ml-md-4">{{ entry.title }}</h6>
              {% endif %}
            {% endif %}

            {% if entry.authors and entry.authors.size > 0 %}
              <h6 class="ml-1 ml-md-4" style="font-size: 0.95rem">
                {{ entry.authors | join: ", " }}
              </h6>
            {% endif %}

            <h6 class="ml-1 ml-md-4" style="font-size: 0.95rem">
              <em>{% if entry.event %}{{ entry.event }}{% endif %}</em>
              {% if entry.location %}{% if entry.event %} · {% endif %}{{ entry.location }}{% endif %}
              {% if entry.date %}{% if entry.event or entry.location %} · {% endif %}{{ entry.date }}{% endif %}
            </h6>

            {% if entry.summary %}
              <p class="ml-1 ml-md-4">{{ entry.summary | markdownify | remove: '<p>' | remove: '</p>' }}</p>
            {% endif %}
          </div>
        {% else %}
          <div class="col-xs-12 col-sm-12 col-md-12">
            {% if entry.title %}
              {% if entry.url %}
                <h6 class="title font-weight-bold ml-1 ml-md-4">
                  <a href="{{ entry.url }}" target="_blank" rel="noopener noreferrer">{{ entry.title }}</a>
                </h6>
              {% else %}
                <h6 class="title font-weight-bold ml-1 ml-md-4">{{ entry.title }}</h6>
              {% endif %}
            {% endif %}

            {% if entry.authors and entry.authors.size > 0 %}
              <h6 class="ml-1 ml-md-4" style="font-size: 0.95rem">
                {{ entry.authors | join: ", " }}
              </h6>
            {% endif %}

            <h6 class="ml-1 ml-md-4" style="font-size: 0.95rem">
              <em>{% if entry.event %}{{ entry.event }}{% endif %}</em>
              {% if entry.location %}{% if entry.event %} · {% endif %}{{ entry.location }}{% endif %}
              {% if entry.date %}{% if entry.event or entry.location %} · {% endif %}{{ entry.date }}{% endif %}
            </h6>

            {% if entry.summary %}
              <p class="ml-1 ml-md-4">{{ entry.summary | markdownify | remove: '<p>' | remove: '</p>' }}</p>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </li>
  {% endfor %}
</ul>
